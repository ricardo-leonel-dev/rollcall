# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=attendance
POSTGRES_USER=attendance
POSTGRES_PASSWORD=change_me_in_production
DB_SCHEMA=public

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://attendance:change_me_in_production@postgres:5432/attendance
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Redis — cola de jobs (voz y foto) ────────────────────────────────────────
# En Docker se resuelve automáticamente; solo cambia si usas Redis externo
REDIS_URL=redis://redis:6379

# ── Bull Board — dashboard de colas (solo superadmin) ────────────────────────
BULL_BOARD_USER=superadmin
BULL_BOARD_PASS=changeme123

# ── AI — endpoints OpenAI-compatible ─────────────────────────────────────────
# LLM_URL: modelo de texto para interpretar comandos de voz
LLM_URL=http://your-llm-host:8080
# WHISPER_URL: transcripción de audio (faster-whisper o compatible)
WHISPER_URL=http://your-whisper-host:8088
# IMAGE_LLM_URL: modelo multimodal para procesar fotos de listas (defaults to LLM_URL si vacío)
IMAGE_LLM_URL=http://your-llm-host:8080
# LLM_API_KEY: Bearer token compartido entre backend y el servidor LLM
LLM_API_KEY=change_me_to_a_random_token

# ── Notifications (optional) ──────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
