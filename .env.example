# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=attendance
POSTGRES_USER=attendance
POSTGRES_PASSWORD=change_me_in_production
DB_SCHEMA=public

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://attendance:change_me_in_production@postgres:5432/attendance
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Tailscale — acceso remoto seguro ─────────────────────────────────────────
# Genera la tuya en: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# ── Redis — cola de procesamiento de voz ─────────────────────────────────────
# En Docker se resuelve automáticamente; solo cambia si usas Redis externo
REDIS_URL=redis://redis:6379

# ── Bull Board — dashboard de colas (solo superadmin) ────────────────────────
BULL_BOARD_USER=superadmin
BULL_BOARD_PASS=changeme123

# ── AI Stack — rig de minería (conectado via Tailscale) ──────────────────────
# 1. Añade el rig a Tailscale (ver ai-models/docker-compose.yml)
# 2. Obtén la IP del rig en: tailscale.com/admin/machines
# 3. Reemplaza 100.x.x.x con esa IP
LLM_URL=http://100.x.x.x:8080
WHISPER_URL=http://100.x.x.x:8088
VISION_MODEL=local
# Mismo valor que LLM_API_KEY en ai-models/envs/2gpu-32k.env
LLM_API_KEY=change_me_to_a_random_token

# ── Notifications (optional) ──────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
